{
  "version": 1,
  "formatters": {
    "simple": {
      "format": "%(asctime)s - %(filename)s - %(levelname)s - %(message)s"
    },
    "level_only": {
      "format": "%(levelname)s - %(message)s"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "level_only",
      "stream": "ext://sys.stdout"
    },
    "file": {
      "class": "logging.FileHandler",
      "level": "DEBUG",
      "formatter": "simple",
      "filename": "app.log"
    }
  },
  "loggers": {
    "basicLogger": {
      "level": "DEBUG",
      "handlers": [
        "console",
        "file"
      ],
      "propagate": "no"
    }
  },
  "root": {
    "level": "DEBUG",
    "handlers": []
  }
}